# ============================================================================
# Copy this file to deploy/.env and fill in real values. Never commit .env.
# ============================================================================

# ── Hostnames (Caddy uses these for routing + cert provisioning) ────────────
# Local dev: *.localhost works out of the box; Caddy serves self-signed certs.
STOREFRONT_HOST=erezer.localhost
ADMIN_HOST=admin.erezer.localhost
API_HOST=api.erezer.localhost
KEYCLOAK_HOSTNAME=auth.erezer.localhost

# Local dev only — switch to Caddy's internal CA so *.localhost names work.
# Comment out / remove in prod so Let's Encrypt is used.
CADDY_GLOBAL_EXTRA=local_certs
# For prod, set your operator email (LE notifies on cert-renewal failure):
ACME_EMAIL=ops@erezer.com

# ── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_DB=erezer
POSTGRES_USER=erezer
POSTGRES_PASSWORD=root

# ── MinIO ──────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=erezer-minio
MINIO_ROOT_PASSWORD=minioadmin123

# ── Keycloak ───────────────────────────────────────────────────────────────
KEYCLOAK_REALM=erezer-admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-please

# ── Customer-JWT secret (≥ 32 chars) ───────────────────────────────────────
EREZER_JWT_SECRET=asfghjklpoiuytrwqasghklmnbvxzxcvbnm1234567890

# ── SMTP ───────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=change-me
MAIL_FROM=no-reply@erezer.com
MAIL_FROM_NAME=Erezer

# ── bKash (production credentials — leave blank for STUB mode in dev) ──────
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=

# ── Sentry ─────────────────────────────────────────────────────────────────
SENTRY_DSN_BACKEND=
SENTRY_DSN_STORE=
SENTRY_DSN_ADMIN=
SENTRY_ENV=prod
SENTRY_RELEASE=erezer-backend@v0.1.0

# ── Container image registry ───────────────────────────────────────────────
IMAGE_REPO_OWNER=your-github-org
IMAGE_TAG=latest

# ── Backups ────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=14
# Optional off-host upload (S3 / R2 / Wasabi). Leave blank for local only.
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
